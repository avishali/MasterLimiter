# Copy to .aax_wraptool.env and fill in (that file is gitignored).
# wraptool_sign_aax.sh sources .aax_wraptool.env on macOS if it exists.
#
# CI: set the same variable names as encrypted secrets instead of using this file.
#
# Build step (CMake), separate from wraptool: Avid AAX SDK root, e.g. aax-sdk-2-8-0
# (must contain Interfaces/ACF). Do not put this in this file for CI unless your
# job also uses it - typically -DAAX_SDK_PATH=... or export AAX_SDK_PATH=...
# export AAX_SDK_PATH="/path/to/aax-sdk-2-8-0"

export AAX_WRAPTOOL_ACCOUNT=""
export AAX_WRAPTOOL_PASSWORD=""
export AAX_WRAPTOOL_SIGNID=""

# Publisher (one path): MasterLimiter-specific Fusion wrap config GUID,
# or PACE customer number + company name. Do not reuse AnalyzerPro values.
# export AAX_WRAPTOOL_WCGUID=""
# export AAX_WRAPTOOL_CUSTOMERNUMBER=""
# export AAX_WRAPTOOL_CUSTOMERNAME=""

# If wraptool says CouldNotFindSignerCredentials:
#   - PACE --allowsigningservice is used only when no signing iLok is plugged in.
#   - Or keep iLok plugged in but install the publisher signing credential on it,
#     then synchronize in iLok License Manager.
# export AAX_WRAPTOOL_ALLOW_SIGNING_SERVICE=1

# Optional: some official wrap lines use --autoinstall on.
# export AAX_WRAPTOOL_AUTOINSTALL=on
# export AAX_WRAPTOOL="/Applications/PACEAntiPiracy/Eden/Fusion/Current/bin/wraptool"
